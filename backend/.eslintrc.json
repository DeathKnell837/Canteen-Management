{
  "eslintConfig": {
    "env": {
      "node": true,
      "es2020": true,
      "jest": true
    },
    "extends": "airbnb-base",
    "parserOptions": {
      "ecmaVersion": 11,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "func-names": "off",
      "object-shorthand": "off",
      "class-methods-use-this": "off",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
    }
  }
}
